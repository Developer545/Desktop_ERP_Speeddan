# ══════════════════════════════════════════════════════════
# Speeddansys License Server — Variables de Entorno
# ══════════════════════════════════════════════════════════

# Conexión a PostgreSQL (usar DATABASE_URL para Neon/cloud)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# O usar variables individuales para desarrollo local:
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=123321
# DB_NAME=speeddansys_licenses
# DB_PORT=5432

# Secreto para JWT (OBLIGATORIO — cambiar en producción)
JWT_SECRET=cambiar-en-produccion

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4000

# Puerto del servidor (solo para ejecución local)
PORT=4000
